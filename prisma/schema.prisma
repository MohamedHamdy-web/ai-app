// Prisma Client
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

//  Models
model User {
  id      String   @id @default(cuid())
  clerkId String   @unique
  history History[]
}

model History {
  id      String @id @default(cuid())
  prompt  String
  result  String
  userId  String
  user    User   @relation(fields: [userId], references: [id])
}